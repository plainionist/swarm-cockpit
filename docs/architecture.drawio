<mxfile host="app.diagrams.net" type="device">
  <diagram id="swarm-cockpit-arch" name="Architecture">
    <mxGraphModel dx="1200" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="swarm-cockpit — watch and drive a SwarmForge agent swarm from the browser" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#13293D;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="1000" height="30" as="geometry" />
        </mxCell>

        <mxCell id="tmux" value="SwarmForge agents  (tmux terminals)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8AA9C9;verticalAlign=top;fontStyle=1;fontColor=#1B4F91;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="270" height="270" as="geometry" />
        </mxCell>
        <mxCell id="pane-a" value="Architect" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#1F2A3A;fontColor=#E6EDF3;fontFamily=monospace;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="165" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pane-i" value="Implementer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#1F2A3A;fontColor=#E6EDF3;fontFamily=monospace;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="232" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pane-v" value="Verifier" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#1F2A3A;fontColor=#E6EDF3;fontFamily=monospace;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="299" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="poller" value="Capture poller&#10;&#10;reads each terminal screen&#10;and types replies back in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF6E7;strokeColor=#D9A400;align=center;verticalAlign=middle;fontColor=#7A5B00;" vertex="1" parent="1">
          <mxGeometry x="380" y="185" width="200" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc" value="Cockpit service&#10;&#10;stores the latest screens,&#10;tracks which agents are active,&#10;queues operator replies,&#10;serves the web dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F6F1;strokeColor=#0F7B6C;align=center;verticalAlign=middle;fontColor=#0A5245;" vertex="1" parent="1">
          <mxGeometry x="650" y="150" width="230" height="150" as="geometry" />
        </mxCell>

        <mxCell id="db" value="In-memory state&#10;&#10;screens · activity · reply queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F4F7;strokeColor=#526476;align=center;verticalAlign=middle;fontColor=#2A3A4A;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="360" width="230" height="90" as="geometry" />
        </mxCell>

        <mxCell id="browser" value="Operator browser&#10;&#10;live mirror of every agent,&#10;active / idle indicator,&#10;type a reply to any agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDED;strokeColor=#BF3B2A;align=center;verticalAlign=middle;fontColor=#8A2A1E;" vertex="1" parent="1">
          <mxGeometry x="950" y="150" width="190" height="150" as="geometry" />
        </mxCell>

        <mxCell id="e-capture" value="screen" style="endArrow=block;html=1;strokeColor=#D9A400;fontColor=#7A5B00;fontSize=12;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;" edge="1" parent="1" source="tmux" target="poller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-sendkeys" value="reply" style="endArrow=block;html=1;strokeColor=#D9A400;fontColor=#7A5B00;fontSize=12;dashed=1;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.65;exitDx=0;exitDy=0;entryX=1;entryY=0.65;entryDx=0;entryDy=0;" edge="1" parent="1" source="poller" target="tmux">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-svc" value="screens / replies" style="endArrow=block;startArrow=block;html=1;strokeColor=#0F7B6C;fontColor=#0A5245;fontSize=12;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="poller" target="svc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-db" value="in-process" style="endArrow=block;startArrow=block;html=1;strokeColor=#526476;fontColor=#2A3A4A;fontSize=12;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc" target="db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-http" value="view / reply" style="endArrow=block;startArrow=block;html=1;strokeColor=#BF3B2A;fontColor=#8A2A1E;fontSize=12;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="browser" target="svc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Screen flow:  agent terminal → poller → service → browser mirror&#10;Reply flow:  browser → service → poller → agent terminal" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontColor=#526476;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="475" width="1100" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
